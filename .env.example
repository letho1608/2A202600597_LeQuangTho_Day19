# LLM Configuration for GraphRAG
# Supported providers: openai, groq, deepseek, nvidia, ollama, anthropic, google

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=  # optional, for OpenAI-compatible endpoints (e.g. DeepSeek: https://api.deepseek.com)
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
